# Copy this to .env and update values

SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database (leave blank to use SQLite)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Feature settings
INVENTORY_RESERVATION_EXPIRY_MINUTES=15
FRAUD_ORDERS_PER_MINUTE=3
FRAUD_HIGH_VALUE_THRESHOLD=10000
